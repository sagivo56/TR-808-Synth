# === נדרש ===
# מפתח ה-API של Anthropic. נשמר בצד שרת בלבד ולעולם לא נחשף בצד לקוח.
# להשגת מפתח: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# === אופציונלי ===
# מודל Claude לשימוש בהערכת קלוריות (חייב לתמוך בקלט תמונות/vision).
# ברירת מחדל: claude-opus-4-8
ANTHROPIC_MODEL=claude-opus-4-8

# נתיב לקובץ ה-SQLite (ברירת מחדל: ./data/app.db)
DATABASE_PATH=./data/app.db
